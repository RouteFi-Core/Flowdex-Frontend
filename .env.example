# ─── Stellar Network ──────────────────────────────────────────────────────────
# "MAINNET" | "TESTNET" | "FUTURENET"
NEXT_PUBLIC_STELLAR_NETWORK=TESTNET

# Horizon RPC endpoint
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org

# Soroban RPC endpoint
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# ─── Flowdex API ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_FLOWDEX_API_URL=https://api.flowdex.io/v1

# Server-side only — never expose to the browser
FLOWDEX_API_SECRET=

# ─── Feature Flags ────────────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_DEV_MODE=true
NEXT_PUBLIC_ENABLE_ROUTE_SIMULATION=true
